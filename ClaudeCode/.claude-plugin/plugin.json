{
  "name": "obsidian-memory",
  "version": "1.0.0",
  "description": "Use Obsidian Vault as persistent memory for Claude Code",
  "author": "ATLKR",
  "skills": ["skills/obsidian-memory"],
  "commands": ["commands/vault-search.md"],
  "mcpServers": [
    {
      "name": "obsidian-memory-server",
      "entrypoint": "mcp-servers/obsidian-memory-server/server.py"
    }
  ],
  "env": {
    "OBSIDIAN_VAULT_PATH": {
      "description": "Path to your Obsidian vault",
      "default": "~/vaults/AllenPrimaryNotes",
      "required": true
    }
  }
}
